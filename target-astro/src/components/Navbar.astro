---
// src/components/Navbar.astro
interface Props {
  variant?: 'home' | 'page';
  rightLinks?: { label: string; href: string; highlight?: boolean }[];
}

const { variant = 'home', rightLinks } = Astro.props;
---

<nav class="fixed w-full z-50 nav-blur border-b border-neutral-800">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
    <a href="/" class="text-xl md:text-2xl font-extrabold tracking-tighter uppercase italic">
      Cyber <span class="text-blue-500">Alliance</span> India
    </a>

    {
      variant === 'home' ? (
        <>
          <button id="menu-toggle" class="md:hidden text-2xl text-white focus:outline-none">
            <i id="menu-icon" class="bi bi-list" />
          </button>

          <div
            id="nav-menu"
            class="hidden absolute top-full left-0 w-full bg-[#0a0a0a]/95 backdrop-blur-xl border-b border-neutral-800 flex-col p-8 space-y-6 md:static md:flex md:flex-row md:w-auto md:bg-transparent md:border-none md:p-0 md:space-y-0 md:space-x-8 text-sm font-semibold text-neutral-400"
          >
            <a href="#about" class="hover:text-white transition block">About</a>
            <a href="#services" class="hover:text-white transition block">Services</a>
            <a href="/portfolio" class="hover:text-white transition block">Portfolio</a>
            <a href="/pricing" class="hover:text-white transition block">Pricing</a>
            <a href="/referral" class="hover:text-white transition block">Refer</a>
            <a href="#testimonials" class="hover:text-white transition block">Reviews</a>
            {/* <a href="#blog" class="hover:text-white transition block">Blog</a> */}
            <a href="#videos" class="hover:text-white transition block">Videos</a>
            <a
              href="#contact"
              class="bg-blue-600 text-white px-6 py-2.5 rounded-full hover:bg-blue-700 transition shadow-lg text-center inline-block"
            >
              Contact
            </a>
          </div>
        </>
      ) : (
        <div class="flex items-center space-x-6">
          {rightLinks?.map((link) => (
            <a
              href={link.href}
              class={
                link.highlight
                  ? 'text-xs font-bold uppercase tracking-widest text-pink-500 hover:text-pink-400 transition'
                  : 'text-xs font-bold uppercase tracking-widest text-neutral-500 hover:text-white transition'
              }
            >
              {link.label}
            </a>
          ))}
          <a
            href="/"
            class="text-xs font-bold uppercase tracking-widest text-neutral-500 hover:text-white transition"
          >
            Back to Home
          </a>
        </div>
      )
    }
  </div>
</nav>

{
  variant === 'home' && (
    <script>
      const menuToggle = document.getElementById('menu-toggle');
      const navMenu = document.getElementById('nav-menu');
      const menuIcon = document.getElementById('menu-icon');
      const navLinks = navMenu?.querySelectorAll('a') ?? [];

      menuToggle?.addEventListener('click', () => {
        const isHidden = navMenu?.classList.toggle('hidden');
        navMenu?.classList.toggle('flex');
        menuIcon?.classList.toggle('bi-list', !!isHidden);
        menuIcon?.classList.toggle('bi-x', !isHidden);
      });

      navLinks.forEach((link) => {
        link.addEventListener('click', () => {
          if (!navMenu?.classList.contains('hidden')) {
            navMenu?.classList.add('hidden');
            navMenu?.classList.remove('flex');
            menuIcon?.classList.replace('bi-x', 'bi-list');
          }
        });
      });
    </script>
  )
}
